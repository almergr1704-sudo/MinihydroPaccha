{
  "entities": {
    "AdminProfile": {
      "title": "AdminProfile",
      "description": "User profile for the administrative system.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["ADMIN", "OPERATOR", "SUPERVISOR"] },
        "createdAt": { "type": "string" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "Client": {
      "title": "Client",
      "description": "A client (Socio or Usuario)",
      "type": "object",
      "properties": {
        "nombres": { "type": "string" },
        "apellidos": { "type": "string" },
        "nombre": { "type": "string" },
        "dni": { "type": "string" },
        "direccion": { "type": "string" },
        "numeroDireccion": { "type": "string" },
        "referenciaDireccion": { "type": "string" },
        "telefono": { "type": "string" },
        "correo": { "type": "string" },
        "codigoSuministro": { "type": "string" },
        "suministros": { "type": "array", "items": { "type": "string" } },
        "tipo": { "type": "string", "enum": ["SOCIO", "USUARIO"] },
        "estado": { "type": "string", "enum": ["ACTIVO", "INACTIVO"] },
        "fechaRegistro": { "type": "string" }
      },
      "required": ["dni", "tipo", "estado", "fechaRegistro"]
    },
    "Consumption": {
      "title": "Consumption",
      "description": "Monthly energy consumption",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "codigoSuministro": { "type": "string" },
        "fechaLectura": { "type": "string" },
        "mes": { "type": "string" },
        "kwh": { "type": "number" },
        "montoCalculado": { "type": "number" },
        "estadoPago": { "type": "string", "enum": ["PENDIENTE", "PAGADO"] }
      },
      "required": ["clientId", "fechaLectura", "mes", "kwh", "montoCalculado", "estadoPago"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction",
      "type": "object",
      "properties": {
        "tipo": { "type": "string", "enum": ["INGRESO", "EGRESO"] },
        "categoria": { "type": "string" },
        "monto": { "type": "number" },
        "fecha": { "type": "string" },
        "descripcion": { "type": "string" },
        "destinatario": { "type": "string" },
        "clientId": { "type": "string" }
      },
      "required": ["tipo", "categoria", "monto", "fecha", "descripcion"]
    },
    "Meeting": {
      "title": "Meeting",
      "description": "A meeting for partners",
      "type": "object",
      "properties": {
        "fecha": { "type": "string" },
        "motivo": { "type": "string" },
        "asistencia": { "type": "object" },
        "createdAt": { "type": "string" }
      },
      "required": ["fecha", "motivo", "asistencia", "createdAt"]
    }
  },
  "firestore": {
    "admins/{adminId}": {
      "schema": { "$ref": "#/entities/AdminProfile" },
      "description": "Admin profiles mapped by Firebase UID"
    },
    "clients/{clientId}": {
      "schema": { "$ref": "#/entities/Client" },
      "description": "All clients in the system"
    },
    "consumptions/{consumptionId}": {
      "schema": { "$ref": "#/entities/Consumption" },
      "description": "Consumptions"
    },
    "transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Financial income and expenses"
    },
    "meetings/{meetingId}": {
      "schema": { "$ref": "#/entities/Meeting" },
      "description": "Meetings and attendance"
    }
  }
}
