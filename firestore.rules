rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { 
      allow read, write: if false; 
    }

    function isSignedIn() { return request.auth != null; }
    function isSystemUser() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isAdmin() { return isSystemUser() && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'ADMIN'; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (adminId == request.auth.uid || isAdmin())
                    && incoming().keys().hasAll(['email', 'role', 'createdAt'])
                    && incoming().email is string
                    && incoming().role in ['ADMIN', 'OPERATOR', 'SUPERVISOR']
                    && incoming().createdAt == request.time;
      allow update: if isSignedIn() && (adminId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    function isValidClient(data) {
      return data.keys().hasAll(['dni', 'tipo', 'estado', 'fechaRegistro'])
        && data.dni is string && data.dni.size() > 0 && data.dni.size() <= 20
        && (!('nombres' in data) || data.nombres is string)
        && (!('apellidos' in data) || data.apellidos is string)
        && (!('nombre' in data) || data.nombre is string)
        && (!('direccion' in data) || data.direccion is string)
        && (!('numeroDireccion' in data) || data.numeroDireccion is string)
        && (!('referenciaDireccion' in data) || data.referenciaDireccion is string)
        && (!('correo' in data) || data.correo is string)
        && (!('telefono' in data) || data.telefono is string)
        && (!('codigoSuministro' in data) || data.codigoSuministro is string)
        && (!('suministros' in data) || data.suministros is list)
        && data.tipo in ['SOCIO', 'USUARIO']
        && data.estado in ['ACTIVO', 'INACTIVO'];
    }

    match /clients/{clientId} {
      allow read: if isSystemUser();
      allow create: if isSystemUser() && isValidClient(incoming());
      allow update: if isSystemUser() && isValidClient(incoming());
      allow delete: if isSystemUser();
    }

    function isValidConsumption(data) {
      return data.keys().hasAll(['clientId', 'fechaLectura', 'mes', 'kwh', 'montoCalculado', 'estadoPago'])
        && data.clientId is string && data.clientId.size() > 0 && data.clientId.size() <= 128
        && (!('codigoSuministro' in data) || data.codigoSuministro is string)
        && data.fechaLectura is string && data.fechaLectura.size() <= 50
        && data.mes is string && data.mes.size() <= 20
        && data.kwh is number
        && data.montoCalculado is number
        && data.estadoPago in ['PENDIENTE', 'PAGADO'];
    }

    match /consumptions/{consumptionId} {
      allow read: if isSystemUser();
      allow create: if isSystemUser() && isValidConsumption(incoming()) && exists(/databases/$(database)/documents/clients/$(incoming().clientId));
      allow update: if isSystemUser() && isValidConsumption(incoming());
      allow delete: if isSystemUser();
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['tipo', 'categoria', 'monto', 'fecha', 'descripcion'])
        && data.tipo in ['INGRESO', 'EGRESO']
        && data.categoria is string && data.categoria.size() > 0 && data.categoria.size() <= 100
        && data.monto is number
        && data.fecha is string && data.fecha.size() <= 60
        && data.descripcion is string && data.descripcion.size() <= 2000
        && (!('destinatario' in data) || data.destinatario is string)
        && (!('clientId' in data) || data.clientId is string);
    }

    match /transactions/{transactionId} {
      allow read: if isSystemUser();
      allow create: if isSystemUser() && isValidTransaction(incoming());
      allow update: if isSystemUser() && isValidTransaction(incoming());
      allow delete: if isSystemUser();
    }

    function isValidMeeting(data) {
      return data.keys().hasAll(['fecha', 'motivo', 'asistencia', 'createdAt'])
        && data.fecha is string && data.fecha.size() <= 60
        && data.motivo is string && data.motivo.size() > 0 && data.motivo.size() <= 600
        && data.asistencia is map;
    }

    match /meetings/{meetingId} {
      allow read: if isSystemUser();
      allow create: if isSystemUser() && isValidMeeting(incoming()) && incoming().createdAt == request.time;
      allow update: if isSystemUser() && isValidMeeting(incoming()) && incoming().createdAt == existing().createdAt;
      allow delete: if isSystemUser();
    }
  }
}
